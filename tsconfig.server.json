{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@tavernos/core": ["./packages/core/src/index.ts"]
    },
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmit": false,
    "outDir": "./dist-server",
    "rootDir": ".",
    "strict": true,
    "noUnusedLocals": false, // TODO: enable after cleanup
    "noUnusedParameters": false, // TODO: enable after cleanup
    "sourceMap": false,
    "declaration": false
  },
  "include": [
    "packages/studio/server/**/*.ts",
    "packages/core/src/**/*.ts"
  ],
  "exclude": [
    "packages/core/tests/**",
    "packages/core/src/**/*.test.ts",
    "packages/studio/server/**/*.test.ts",
    "node_modules"
  ]
}
