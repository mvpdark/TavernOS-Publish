# TavernOS LLM Configuration
# Copy to .env and fill in your API key

# Primary LLM provider
TAVERNOS_LLM_PROVIDER=custom
TAVERNOS_LLM_BASE_URL=https://api.openai.com/v1
TAVERNOS_LLM_API_KEY=sk-...
TAVERNOS_LLM_MODEL=gpt-4o

# Optional: service name for provider bank
TAVERNOS_LLM_SERVICE=openai

# Optional: generation parameters
TAVERNOS_LLM_TEMPERATURE=0.7
TAVERNOS_DEFAULT_LANGUAGE=zh
